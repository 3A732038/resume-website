# Prod 前端：只負責 build 出靜態檔，丟進共享 volume 給共用 nginx 服務。
# 不再內建 nginx（改由 ../reverse-proxy 的共用 nginx 直接 serve 靜態檔）。
FROM node:20-alpine

WORKDIR /app

COPY package.json .
RUN npm install

COPY . .
RUN npm run build

# 容器啟動時：清掉 volume 舊檔，把這次 build 的產物複製進去，然後結束。
# 這是「build-only」容器——任務就是填充共享 volume，跑完即退出。
CMD ["sh", "-c", "rm -rf /output/* && cp -r /app/dist/. /output/ && echo 'prod 靜態檔已更新到共享 volume'"]
